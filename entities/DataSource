{
  "name": "DataSource",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da fonte de dados"
    },
    "institution": {
      "type": "string",
      "description": "Institui\u00e7\u00e3o governamental respons\u00e1vel"
    },
    "institution_acronym": {
      "type": "string",
      "description": "Sigla da institui\u00e7\u00e3o"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o acad\u00eamica da fonte"
    },
    "historical_context": {
      "type": "string",
      "description": "Contexto hist\u00f3rico e relev\u00e2ncia da base de dados"
    },
    "theme": {
      "type": "string",
      "enum": [
        "Clima e Atmosfera",
